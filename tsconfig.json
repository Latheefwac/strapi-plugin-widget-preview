{
  "compilerOptions": {
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": false,
    "skipLibCheck": true,
    "moduleResolution": "node",
    "module": "commonjs",
    "target": "ES2020",
    "jsx": "react-jsx",
    "baseUrl": ".",
    "lib": ["ES2020", "DOM", "DOM.Iterable"]
  },
  "include": ["admin/src", "server/src", "*.ts"],
  "exclude": ["node_modules", "dist", "build", ".cache", "**/*.test.ts"]
}
